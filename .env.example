# ============================================
# 应用基础
# ============================================
NODE_ENV=development
# 用于签 JWT，生产环境请用 openssl rand -hex 32 生成
JWT_SECRET=please_change_me_to_a_random_32_byte_string
# 管理员账号（首次启动种子时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# ============================================
# 数据库
# ============================================
# 开发用 SQLite（无需额外服务）
DATABASE_URL="file:./dev.db"
# 生产用 Postgres，举例：
# DATABASE_URL="postgresql://user:pass@localhost:5432/yuce?schema=public"

# ============================================
# Football Data（免费数据源）
# 注册：https://www.football-data.org/client/register
# ============================================
FOOTBALL_DATA_API_KEY=your_api_key_here
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# ============================================
# Tron / TRC20 USDT
# ============================================
# Tron 网络：mainnet | shasta(测试网) | nile(测试网)
TRON_NETWORK=shasta
TRON_FULL_NODE=https://api.shasta.trongrid.io
TRON_SOLIDITY_NODE=https://api.shasta.trongrid.io
TRON_EVENT_SERVER=https://api.shasta.trongrid.io
# 申请 https://www.trongrid.io/ 拿 API Key（免费档 10 万次/天）
TRON_API_KEY=

# USDT TRC20 合约地址
# 主网：TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Shasta 测试网：TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
USDT_CONTRACT_ADDRESS=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs

# 平台热钱包（接收充值 + 发送提现的钱包）
# 不要使用真实大额钱包！MVP 建议金额上限，每日定时归集到冷钱包
HOT_WALLET_ADDRESS=
HOT_WALLET_PRIVATE_KEY=

# ============================================
# 业务参数
# ============================================
# 平台抽水比例（基点：100 = 1%，500 = 5%，0 = 无抽水）
PLATFORM_RAKE_BPS=300
# 单笔最小/最大下注 USDT
MIN_BET_USDT=1
MAX_BET_USDT=500
# 单笔最小提现 USDT
MIN_WITHDRAW_USDT=10
# 充值确认所需区块数
DEPOSIT_CONFIRMATIONS=20
# 扫块间隔（秒）
SCAN_INTERVAL_SECONDS=30
